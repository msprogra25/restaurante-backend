{
  "name": "comanda-restaurante",
  "version": "1.0.0",
  "description": "Backend real (Node.js + Express + SQLite) do sistema de restaurante Comanda",
  "main": "server.js",
  "scripts": {
    "build": "npm --prefix frontend ci && npm --prefix frontend run build -- --outDir ../public --emptyOutDir",
    "start": "node server.js",
    "dev": "node server.js"
  },
  "dependencies": {
    "@netlify/database": "^1.1.0",
    "@netlify/functions": "^5.3.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^1.0.0-beta.22",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.7.5"
  },
  "engines": {
    "node": "20.x"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "drizzle-kit": "^1.0.0-beta.22",
    "typescript": "^7.0.2"
  }
